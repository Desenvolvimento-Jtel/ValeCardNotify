# ── Site Valecard ──────────────────────────────────
SITE_URL=https://siag3.valecard.com.br/
SITE_USERNAME=ROBOAUTOMAT
SITE_PASSWORD=sua_senha_aqui

# ── Microsoft Graph API ───────────────────────────
GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_SECRET=sua_client_secret_aqui
GRAPH_MAILBOX_ENVIO=robo@suaempresa.com.br

# ── E-mail técnico (xlsx em anexo) ────────────────
EMAIL_DESTINATARIOS=tecnico1@empresa.com,tecnico2@empresa.com

# ── E-mail de aviso (link justificativa) ─────────
EMAIL_DESTINATARIOS_AVISO=gestor1@empresa.com,gestor2@empresa.com
EMAIL_LINK_JUSTIFICATIVA=https://sistema.suaempresa.com.br

# ── MySQL ─────────────────────────────────────────
MYSQL_HOST=ip_ou_dominio_do_banco
MYSQL_PORT=3306
MYSQL_DB=nome_do_banco
MYSQL_USER=usuario_mysql
MYSQL_PASSWORD=senha_mysql
MYSQL_TABELA=controle_gestao_analitico
